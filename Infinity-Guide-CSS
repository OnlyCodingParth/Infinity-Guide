.strategy-card.gold { border-left-color: #FF8A00; }
.strategy-card.green { border-left-color: #17C964; }
.strategy-title { font-family: 'Poppins', sans-serif; font-weight: 800; color: #F0F4FF; font-size: 15px; margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
.strategy-list { list-style: none; }
.strategy-list li { font-size: 13px; color: rgba(255,255,255,0.8); padding: 5px 0; border-bottom: 1px dashed rgba(255,255,255,0.08); display: flex; gap: 9px; align-items: flex-start; line-height: 1.5; }
.strategy-list li:last-child { border-bottom: none; }
.strategy-list .num { background: var(--navy); color: var(--saffron); width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 10.5px; font-weight: 800; flex-shrink: 0; margin-top: 1px; }

/* Highlight/info boxes */
.highlight-box { background: rgba(255,138,0,0.08); border-left: 4px solid #FF8A00; border-radius: 0 11px 11px 0; padding: 12px 16px; font-size: 13.5px; color: rgba(255,255,255,0.85); margin-top: 14px; line-height: 1.6; }
.highlight-box strong { color: #FF8A00; }
.info-box { background: rgba(10,31,107,0.4); border-left: 4px solid #173EA5; border-radius: 0 11px 11px 0; padding: 12px 16px; font-size: 13.5px; color: rgba(255,255,255,0.85); margin-top: 14px; line-height: 1.6; }

/* Exam box */
.exam-box {
  background: rgba(255,255,255,0.04); border-radius: var(--radius);
  padding: 20px 24px; border: 1px solid rgba(255,255,255,0.09);
  margin-bottom: 16px;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 8px 32px rgba(0,0,0,0.3);
}
.exam-box h4 { font-family: 'Poppins', sans-serif; font-size: 15px; font-weight: 800; color: #F0F4FF; margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
.exam-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px dashed rgba(255,255,255,0.08); font-size: 13px; }
.exam-row:last-child { border-bottom: none; }
.exam-row .label { color: rgba(255,255,255,0.6); font-weight: 500; }
.exam-row .value { font-weight: 700; color: #F0F4FF; text-align: right; max-width: 60%; }

/* Tables: comp, res */
.res-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-top: 14px; }
.res-table th { background: rgba(10,31,107,0.8); color: #FF8A00; padding: 11px 15px; text-align: left; font-family: 'Poppins', sans-serif; font-size: 13px; font-weight: 700; }
.res-table th:first-child { border-radius: 12px 0 0 0; }
.res-table th:last-child { border-radius: 0 12px 0 0; }
.res-table td { padding: 10px 15px; border-bottom: 1px solid rgba(255,255,255,0.06); vertical-align: top; line-height: 1.45; color: rgba(255,255,255,0.8); }
.res-table tr:nth-child(even) td { background: rgba(255,255,255,0.03); }
.res-table a { color: #00A9A5; text-decoration: none; font-weight: 600; }
.res-table a:hover { color: #FF8A00; text-decoration: underline; }

/* YouTube cards */
.yt-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px,1fr)); gap: 14px; margin-top: 14px; }
.yt-card {
  background: rgba(255,255,255,0.04); border-radius: 13px; padding: 16px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  border-left: 4px solid #FF0000;
  border-top: 1px solid rgba(255,255,255,0.09);
  border-right: 1px solid rgba(255,255,255,0.09);
  border-bottom: 1px solid rgba(255,255,255,0.09);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  transition: all 0.22s;
}
.yt-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,0,0,0.4); border-left-color: #FF4444; }
.yt-name { font-family: 'Poppins', sans-serif; font-weight: 800; color: #F0F4FF; font-size: 14px; margin-bottom: 4px; }
.yt-subject { font-size: 12px; font-weight: 700; color: #FF6666; margin-bottom: 6px; }
.yt-why { font-size: 12.5px; color: rgba(255,255,255,0.6); line-height: 1.45; }

/* Stage tabs (communication page) */
.stage-tabs { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 28px; }
.stage-tab {
  padding: 9px 20px; border-radius: 22px;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.7);
  font-size: 13px; font-weight: 600; cursor: pointer;
  transition: all 0.2s; font-family: 'Inter', sans-serif;
}
.stage-tab:hover { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.9); border-color: rgba(255,255,255,0.2); }
.stage-tab.active { background: rgba(255,138,0,0.15); color: #FF8A00; border-color: rgba(255,138,0,0.4); box-shadow: 0 4px 14px rgba(255,138,0,0.15); }
.stage-panel { display: none; }
.stage-panel.active { display: block; }

/* Communication cards */
.comm-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px,1fr)); gap: 18px; margin-bottom: 24px; }
.comm-card {
  background: rgba(255,255,255,0.04); border-radius: var(--radius);
  box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  overflow: hidden; transition: all 0.25s;
  border: 1px solid rgba(255,255,255,0.09);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}
.comm-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,0,0,0.4); border-color: rgba(255,138,0,0.3); }
.comm-header {
  padding: 15px 18px; background: linear-gradient(135deg, #0A1F6B, #173EA5);
  display: flex; align-items: center; gap: 11px;
}
.comm-icon { width: 38px; height: 38px; background: rgba(255,255,255,0.12); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
.comm-title { font-family: 'Poppins', sans-serif; font-weight: 700; color: #fff; font-size: 14px; }
.comm-sub { font-size: 11px; color: rgba(255,255,255,0.6); margin-top: 2px; }
.comm-body { padding: 16px 18px; }

/* Sidebar overlay */
.sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 400; }
.sidebar-overlay.show { display: block; }

/* ══════════════════════════════════
   FOOTER
   ══════════════════════════════════ */
.footer {
  background: #040912;
  border-top: 1px solid rgba(255,255,255,0.06);
  padding: 3rem 3rem 2.5rem;
}
.footer-inner {
  max-width: 960px; margin: 0 auto;
  display: flex; align-items: center;
  justify-content: space-between; flex-wrap: wrap; gap: 1rem;
}
.footer-logo {
  font-family: 'Poppins', sans-serif; font-size: 22px; font-weight: 800;
  color: var(--saffron); display: flex; align-items: center; gap: 8px;
  letter-spacing: -0.02em;
}
.footer-links { display: flex; gap: 1.75rem; flex-wrap: wrap; }
.footer-links a { font-size: 13px; color: rgba(255,255,255,0.45); text-decoration: none; transition: color 0.2s; }
.footer-links a:hover { color: var(--saffron); }
.footer-copy {
  font-size: 12px; color: rgba(255,255,255,0.3);
  width: 100%; text-align: center; padding-top: 0.75rem;
  border-top: 1px solid rgba(255,255,255,0.07); margin-top: 0.5rem;
}

/* ══════════════════════════════════
   ANIMATIONS & REVEALS
   ══════════════════════════════════ */
.reveal { opacity: 0; transform: translateY(22px); transition: opacity 0.65s ease, transform 0.65s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }
.d1 { transition-delay: 0.12s; }
.d2 { transition-delay: 0.24s; }
.d3 { transition-delay: 0.36s; }
.fade-in { opacity: 0; transform: translateY(20px); transition: opacity 0.55s ease, transform 0.55s ease; }
.fade-in.visible { opacity: 1; transform: translateY(0); }

@keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
@keyframes bounce {
  0%,100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(8px); }
}

/* ══════════════════════════════════
   FLOATING ELEMENTS
   ══════════════════════════════════ */
.scroll-progress {
  position: fixed; top: 0; left: 0; height: 3px;
  background: var(--grad-saffron); z-index: 9999;
  transition: width 0.1s linear; width: 0%;
}
.back-to-top {
  position: fixed; bottom: 28px; right: 28px;
  width: 46px; height: 46px; border-radius: 14px;
  background: rgba(255,138,0,0.15); color: #FF8A00;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; cursor: pointer;
  box-shadow: 0 6px 24px rgba(0,0,0,0.4);
  border: 1px solid rgba(255,138,0,0.3); transition: all 0.3s;
  opacity: 0; pointer-events: none;
  font-family: monospace;
  backdrop-filter: blur(10px);
}
.back-to-top.visible { opacity: 1; pointer-events: all; }
.back-to-top:hover { transform: translateY(-3px); box-shadow: 0 10px 32px rgba(255,138,0,0.3); background: rgba(255,138,0,0.25); }

/* ══════════════════════════════════
   RESPONSIVE
   ══════════════════════════════════ */
@media (max-width: 768px) {
  .hero { padding: 4rem 1.5rem 3.5rem; }
  .section { padding: 3.5rem 1.5rem; }
  .about-grid { grid-template-columns: 1fr; }
  .who-grid { grid-template-columns: 1fr; }
  .find-grid { grid-template-columns: 1fr; }
  .quote-section { padding: 4rem 1.5rem; }
  .footer { padding: 2.5rem 1.5rem; }
  .footer-inner { flex-direction: column; align-items: flex-start; }
  .greeting-pill { display: none; }
  .hero-icons { display: none; }
  .page-content { padding: 18px 16px 60px; }
  .page-hero { padding: 24px 22px; }
  .page-hero h1 { font-size: 1.5rem; }
  .subject-grid { grid-template-columns: 1fr; }
  .grade-tabs { gap: 6px; }
  .grade-tab { padding: 7px 14px; font-size: 12px; }
  .skill-grid { grid-template-columns: 1fr; }
  .career-big-grid { grid-template-columns: 1fr; }
  .topic-grid { grid-template-columns: 1fr 1fr; }
  .resource-grid { grid-template-columns: 1fr; }
  .activity-section { padding: 18px 16px; }
  .section-tabs { padding: 10px; gap: 6px; }
  .section-tab { padding: 7px 12px; font-size: 12px; }
}
@media (max-width: 440px) {
  .topic-grid { grid-template-columns: 1fr; }
}

/* ── Suppress reduced motion ── */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}

// ── CINEMATIC TOPBAR SCROLL ──
(function() {
  var tb = document.getElementById('cine-topbar');
  if (!tb) return;
  window.addEventListener('scroll', function() {
    // Only toggle scroll state on home page; inner pages always stay dark
    if (tb.classList.contains('always-dark')) return;
    if (window.scrollY > 30) tb.classList.add('scrolled');
    else tb.classList.remove('scrolled');
  }, { passive: true });
})();

// ── CINEMATIC VIDEO FADE-IN ──
(function() {
  var v = document.getElementById('cineHeroVideo');
  if (!v) return;
  v.addEventListener('loadeddata', function() { v.classList.add('loaded'); });
  v.addEventListener('error', function() {
    var hero = document.querySelector('.cine-hero');
    if (hero) hero.style.background = 'linear-gradient(135deg,#071A52 0%,#0A1F6B 60%,#173EA5 100%)';
  });
})();

// ── CINEMATIC HERO VISIBILITY: hide when not on home ──
function updateCineHero(pid) {
  var hero = document.getElementById('cine-hero-section');
  var tb = document.getElementById('cine-topbar');
  if (!hero) return;
  if (pid === 'home') {
    hero.style.display = '';
    // On home page: transparent at top, dark on scroll
    if (tb) {
      tb.classList.remove('scrolled', 'always-dark');
      if (window.scrollY > 30) tb.classList.add('scrolled');
    }
  } else {
    hero.style.display = 'none';
    // On inner pages: always show solid dark topbar
    if (tb) {
      tb.classList.remove('scrolled');
      tb.classList.add('always-dark');
    }
  }
}

// ── SYNC CINE NAV ACTIVE STATE ──
var _cineNavMap = {
  'home': 'cnav-home', 'guide-5-10': 'cnav-guide-5-10',
  'science-11-12': 'cnav-science-11-12', 'careers': 'cnav-careers',
  'exams': 'cnav-exams', 'resources': 'cnav-resources'
};
function updateCineNav(pid) {
  Object.values(_cineNavMap).forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.classList.remove('active');
  });
  if (_cineNavMap[pid]) {
    var el = document.getElementById(_cineNavMap[pid]);
    if (el) el.classList.add('active');
  }
}

